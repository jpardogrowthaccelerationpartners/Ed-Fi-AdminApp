# Common
NPG_POOLING_ENABLED=true
NPG_API_MAX_POOL_SIZE_ODS=20
NPG_API_MAX_POOL_SIZE_ADMIN=20
NPG_API_MAX_POOL_SIZE_SECURITY=20
NPG_API_MAX_POOL_SIZE_MASTER=20

TPDM_ENABLED=true
LOGS_FOLDER=./logs
BASE_URL=https://localhost
BASE_URL_DEV=http://localhost:3333
ALLOWED_ORIGINS=${BASE_URL}

# Ed-Fi v7.3.0

# NOTE: All odsV7-*-db-ods containers (single-tenant and multi-tenant, v2 and
# v3) are now built locally from compose/DB-Ods instead of pulling an image
# from Docker Hub. ODS_DB_IMAGE_7X / ODS_DB_TAG_7X are no longer used by any
# v7.3 ODS DB container; they are kept below only for reference/rollback and
# are still used by the v6.2 topology's own ODS_DB_IMAGE_6X / ODS_DB_TAG_6X
# variables.
#ODS_DB_IMAGE_7X=ods-api-db-ods-minimal
#ODS_DB_TAG_7X=v7.3@sha256:579a324a39d8439f1b4087112f586ba665ca292e8ddaf3923b6718f11ac8ab0e

# compose/DB-Ods custom image settings, shared by every odsV7-*-db-ods
# container (single-tenant and multi-tenant, v2 and v3).
# SQL_BACKUPS_FOLDER is a host path to a folder containing your own
# EdFi.Ods.Minimal.Template.sql and EdFi.Ods.Populated.Template.sql backup
# files. You must provide these files; they are not included in this repo.
SQL_BACKUPS_FOLDER=./db-backup
MINIMAL_SQL_PATH=/var/opt/pgsql/data/sql-backups/EdFi.Ods.Minimal.Template.sql
POPULATED_SQL_PATH=/var/opt/pgsql/data/sql-backups/EdFi.Ods.Populated.Template.sql
# EDFI_ODS_DATASET controls which template EdFi_Ods is cloned from: minimal | populated
EDFI_ODS_DATASET=minimal
POSTGRES_PORT=5432

ODS_API_TAG_7X=v7.3@sha256:cd359af95d9cdb68753c67037b9c89f2103c0f706db34bba291321b396e16869

# ... "pre" below brings in the latest pre-release version of the Admin API 2.4
ADMIN_DB_TAG_7X=pre
ADMIN_API_TAG_7X=pre
#ADMIN_API_TAG_7X=pre@sha256:460c8940527327e916662ad90ed65c72d6f76aeea809607ca1c096f99f224af4
#ADMIN_DB_TAG_7X=v2.2.1@sha256:1d69fa553fcd3e1d27a35485e2c0f428b95cf1a642dd019844a81af4def01714
#ADMIN_API_TAG_7X=v2.2.1@sha256:329e3d31b90e03e18ded7a586e42d54ab934ae0a252036d36c0fe28bd66dc3c7

ODS_V7_ADMIN_V2_MULTI_API_VIRTUAL_NAME=odsv7-adminv2-multi-api
ODS_V7_ADMIN_V2_MULTI_ADMIN_API_VIRTUAL_NAME=odsv7-adminv2-multi-adminapi

ODS_V7_ADMIN_V2_SINGLE_API_VIRTUAL_NAME=odsv7-adminv2-single-api
ODS_V7_ADMIN_V2_SINGLE_ADMIN_API_VIRTUAL_NAME=odsv7-adminv2-single-adminapi
ODS_V7_ADMIN_V2_SINGLE_API_HEALTHCHECK="wget --no-check-certificate --spider http://localhost/health"
ODS_V7_ADMIN_V2_SINGLE_ADMIN_API_HEALTHCHECK="wget --no-check-certificate --spider http://localhost/health"

ODS_V7_ADMIN_V2_MULTI_API_HEALTHCHECK_TEST="wget --no-check-certificate --spider http://localhost/health"
ODS_V7_ADMIN_V2_MULTI_ADMIN_API_HEALTHCHECK_TEST="wget --no-check-certificate  --header=\"tenant: tenant1\" --spider http://localhost/health"

MULTITENANCY_ENABLED=true
PAGING_OFFSET=0
PAGING_LIMIT=25
ENABLE_APPLICATION_RESET_ENDPOINT=true
SWAGGER_DEFAULT_TENANT=tenant1
# Generate a new encryption key using `openssl rand -base64 32`
ODS_CONNECTION_STRING_ENCRYPTION_KEY=vLgnKf+MyoAsEmeGsh+n+rKRN1bGS8s1b0eCo6zc5+o=

ODS_V7_ADMIN_V2_MULTI_API_DISCOVERY_URL=https://localhost/odsv7-adminv2-multi-api
ODS_V7_ADMIN_V2_SINGLE_API_DISCOVERY_URL=https://localhost/odsv7-adminv2-single-api

# Ed-Fi v7.x - Admin API v3
ODS_V7_ADMIN_V3_MULTI_API_VIRTUAL_NAME=odsv7-adminv3-multi-api
ODS_V7_ADMIN_V3_MULTI_ADMIN_API_VIRTUAL_NAME=odsv7-adminv3-multi-adminapi

ODS_V7_ADMIN_V3_SINGLE_API_VIRTUAL_NAME=odsv7-adminv3-single-api
ODS_V7_ADMIN_V3_SINGLE_ADMIN_API_VIRTUAL_NAME=odsv7-adminv3-single-adminapi
ODS_V7_ADMIN_V3_SINGLE_API_HEALTHCHECK="wget --no-check-certificate --spider http://localhost/health"
ODS_V7_ADMIN_V3_SINGLE_ADMIN_API_HEALTHCHECK="wget --no-check-certificate --spider http://localhost/health"

ODS_V7_ADMIN_V3_MULTI_API_HEALTHCHECK_TEST="wget --no-check-certificate --spider http://localhost/health"
ODS_V7_ADMIN_V3_MULTI_ADMIN_API_HEALTHCHECK_TEST="wget --no-check-certificate  --header=\"tenant: tenant1\" --spider http://localhost/health"

ODS_V7_ADMIN_V3_MULTI_API_DISCOVERY_URL=https://localhost/odsv7-adminv3-multi-api
ODS_V7_ADMIN_V3_SINGLE_API_DISCOVERY_URL=https://localhost/odsv7-adminv3-single-api

# Ed-Fi v6.2.0
# Next two lines are for the minimal template
ODS_DB_IMAGE_6X=ods-api-db-ods
ODS_DB_TAG_6X=v2.3.5@sha256:fc2ebd13d53911364c6cd76c3509f607350eb32021fcebf2fe65e7a8e6faa4f0
# These two are for the populated template
#ODS_DB_IMAGE_6X=ods-api-db-ods-sandbox
#ODS_DB_TAG_6X=v2.3.5@sha256:6955ac921eb79d2fd0557befba327ebee6ab98371e77034cbb52f5e1ed088238

ODS_API_TAG_6X=v2.3.5@sha256:28774e9206ba3ab074518c97924ca7618d0e81a4793b3bd1ef6be4649cc530d3

#ADMIN_DB_TAG_6X=v1.4.3@sha256:69120328487ac0e0988d52fc161153c17eba32b7a4597afaccc0b3edf44f1cd8
#ADMIN_TAG_6X=v1.4.2@sha256:518df6820e019003939a4842d86533314776b16d190606e4c26ecb22b3341adb
# use "pre" below to get the latest pre-release version of the Admin API 2.3
ADMIN_DB_TAG_6X=v1.4.3@sha256:69120328487ac0e0988d52fc161153c17eba32b7a4597afaccc0b3edf44f1cd8
ADMIN_TAG_6X=pre

V6_ODS_VIRTUAL_NAME=v6-api
V6_ADMIN_API_VIRTUAL_NAME=v6-adminapi
V6_API_HEALTHCHECK_TEST="wget --no-check-certificate --spider http://localhost/health"
V6_ADMIN_API_HEALTHCHECK_TEST="wget --no-check-certificate --spider http://localhost/health"
# ... use 6.1 below even for ODS/API 6.2
ODS_API_VERSION_6X=6.1
API_INTERNAL_URL=http://v6-api:8080
ODS_API_62_DISCOVERY=https://localhost/v6-api

# Admin API encryption - generate a new signing key using `openssl rand -base64 32`
SIGNING_KEY=v+R+atm4BwN+Y8EavGPqGs3Gt1kBX3qEBZmwyZBG95I=

# Keycloak
KEYCLOAK_TAG=26.1@sha256:044a457e04987e1fff756be3d2fa325a4ef420fa356b7034ecc9f1b693c32761
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KC_LOG_CONSOLE_LEVEL=error
KEYCLOAK_EDFIADMINAPP_CLIENT_SECRET=big-secret-123
KEYCLOAK_EDFIADMINAPP_DEV_CLIENT_SECRET=big-secret-123

# FE Configuration
VITE_API_URL=https://localhost/adminapp-api
VITE_OIDC_ID=1
VITE_BASE_PATH=/adminapp/
VITE_HELP_GUIDE=https://docs.ed-fi.org/reference/admin-app-v4
VITE_STARTING_GUIDE=${VITE_HELP_GUIDE}/system-administrators/global-administration-tasks
VITE_CONTACT=https://community.ed-fi.org
VITE_IDP_ACCOUNT_URL=https://localhost/auth/realms/edfi/account/
VITE_SHOW_REQUEST_CERTIFICATION=false
VITE_APPLICATION_NAME="Ed-Fi Admin App"

# Database engine pgsql or mssql
DB_ENGINE=pgsql
DB_SSL=false # or "true" if you want encryption
DB_TRUST_CERTIFICATE=false # or "true" if you want to trust the server certificate
DB_TTL_IN_MINUTES=120 # Time to live for DB sessions in minutes
## PostgreSQL Configuration (uncomment to use PostgreSQL instead of SQL Server)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
ADMIN_APP_DB_NAME=sbaa
# .. if you change this port, you must also update local.js
POSTGRES_PORT_EXPOSED=5432
## MSSQL Configuration (uncomment to use SQL Server instead of PostgreSQL)
# MSSQL_PORT_EXPOSED=1433
# MSSQL_ACCEPT_EULA=Y
# MSSQL_SA_PASSWORD=  # Required — no default is provided. Set a strong password before running.
# MSSQL_IMAGE_TAG=2022-latest

# API Configuration
# For Node to trust the self-signed certificate
NODE_EXTRA_CA_CERTS=/app/ssl/server.crt
SSL_VERIFICATION=true # Set to false to disable SSL verification for outgoing requests (e.g., to the database or Yopass). Not recommended for production environments.
USE_YOPASS=true
YOPASS_URL=http://edfiadminapp-yopass:80
# Certification artifact configuration
CERT_BRUNO_SRC_REF='v2.1.0' # Tag name or commit ref
CERT_BRUNO_SRC_CHECKSUM='71840f51f464c60d7b90c7bbf08d9be039df291d51dd69085ffc4703b98f11e6' # SHA-256 checksum of the artifact zip file for integrity verification
## CERT_BRUNO_ON_DOWNLOAD_ERROR => Whether to error out or just warn if there's a problem downloading or initializing the certification artifact.
## Note: If set to 'warning' and there's a problem with the certification artifact, any API routes depending on it will fail at runtime when they attempt to use the artifact.
CERT_BRUNO_ON_DOWNLOAD_ERROR='warning' # error | warning.
## DB_SECRET_VALUE — JSON object with DB connection settings for the API container.
## Set one of the following depending on the value of DB_ENGINE above.
## PostgreSQL (DB_ENGINE=pgsql):
DB_SECRET_VALUE={"DB_HOST":"edfiadminapp-postgres","DB_PORT":5432,"DB_USERNAME":"postgres","DB_PASSWORD":"postgres","DB_DATABASE":"sbaa"}
## SQL Server (DB_ENGINE=mssql):
# DB_SECRET_VALUE={"MSSQL_DB_HOST":"edfiadminapp-mssql","MSSQL_DB_PORT":1433,"MSSQL_DB_USERNAME":"sa","MSSQL_DB_PASSWORD":"YourStrong!Passw0rd","MSSQL_DB_DATABASE":"sbaa"}