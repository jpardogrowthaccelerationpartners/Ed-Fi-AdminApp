  "scripts": {
    "start": "nx run-many -p api fe -t serve",
    "build": "npm run build:fe && npm run build:api",
    "build:fe": "nx run fe:build",
    "build:api": "nx run api:build",
    "build-storybook:common-ui": "nx run common-ui:build-storybook",
    "storybook": "nx run common-ui:storybook",
    "start:api": "nx run api:serve --configuration=production",
    "start:api:dev": "cross-env NODE_TLS_REJECT_UNAUTHORIZED=0 nx run api:serve",
    "start:fe:dev": "nx run fe:serve",
    "migrations:generate": "nx run api:migrations:generate --name",
    "migrations:run": "nx run api:migrations:run",
    "migrations:run:mssql": "cross-env DB_ENGINE=mssql nx run api:migrations:run",
    "migrations:revert": "nx run api:migrations:revert",
    "generate:icons": "./scripts/generateIcons.sh",
    "test:api": "nx run api:test",
    "test:fe": "nx run fe:test",
    "test:models-server": "nx run models-server:test",
    "test:utils": "nx run utils:test",
    "test:models": "nx run models:test",
    "lint:check": "eslint .",
    "lint:fix": "eslint --fix .",
    "prettier:check": "prettier --check .",
    "prettier:write": "prettier --write .",
    "sandworm:audit": "cross-env NODE_OPTIONS=\"--max-old-space-size=16384\" npx @sandworm/audit@latest"
